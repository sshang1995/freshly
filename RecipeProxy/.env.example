# Copy to .env and fill in your values (never commit .env)

# Required: your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required in production: shared secret between this proxy and the iOS app.
# Generate with: openssl rand -hex 32
PROXY_TOKEN=

# Optional: port (defaults to 3000; most hosting platforms set this automatically)
PORT=3000
